---
import { getCollection } from 'astro:content';
import ArticleCard from '../../../components/ArticleCard.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Layout from '../../../layouts/Layout.astro';
import { sortArticles } from '../../../lib/site';

const articles = sortArticles(
  (await getCollection('articles', ({ data }) => !data.draft)).filter(
    (article) => article.data.author === 'Aditya Argadinata',
  ),
);
---

<Layout
  title="Aditya Argadinata"
  description="Author page for Aditya Argadinata, covering soccer explainers and news context for American fans."
>
  <main class="mx-auto max-w-[90rem] px-4 py-8 sm:px-6 lg:px-8">
    <Breadcrumbs items={[{ label: 'Authors' }, { label: 'Aditya Argadinata' }]} />
    <header class="mt-8 grid gap-8 border-b border-slate-200 pb-8 md:grid-cols-[220px_1fr]">
      <div class="flex h-44 w-44 items-center justify-center bg-white text-5xl font-black text-emerald-700 ring-1 ring-slate-200">AA</div>
      <div>
        <p class="text-sm font-black uppercase tracking-wide text-emerald-700">Author</p>
        <h1 class="mt-3 text-4xl font-black tracking-tight text-slate-950">Aditya Argadinata</h1>
        <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-600">
          Aditya writes soccer explainers and news context for US readers, with a focus on making global soccer formats, rules, transfers, and business stories easier to understand.
        </p>
      </div>
    </header>
    <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {articles.map((article) => <ArticleCard article={article} />)}
    </div>
  </main>
</Layout>
