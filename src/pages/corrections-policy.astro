import PolicyPage from '../components/PolicyPage.astro';
---

<PolicyPage
  title="Corrections Policy"
  description="How Kixball handles corrections and updates."
>
  <p>
    If an article contains an error, the site will correct it as soon as reasonably possible after review. Material corrections should be reflected in the updated date or an editor’s note when appropriate.
  </p>
  <p>
    Readers can submit correction requests through the contact page with the article URL and supporting evidence.
  </p>
</PolicyPage>
