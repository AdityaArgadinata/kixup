---
import { getCollection } from 'astro:content';
import ArticleCard from '../../components/ArticleCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Layout from '../../layouts/Layout.astro';
import { slugify, sortArticles } from '../../lib/site';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  const tagMap = new Map<string, string>();

  articles.flatMap((article) => article.data.tags).forEach((tag) => {
    tagMap.set(slugify(tag), tag);
  });

  return [...tagMap.entries()].map(([slug, tag]) => ({
    params: { tag: slug },
    props: { tag, articles },
  }));
}

const { tag, articles } = Astro.props;
const taggedArticles = sortArticles(
  articles.filter((article) => article.data.tags.some((item) => slugify(item) === slugify(tag))),
);
---

<Layout title={`${tag} Articles`} description={`Soccer explainers and news context tagged ${tag}.`}>
  <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <Breadcrumbs items={[{ label: `Tag: ${tag}` }]} />
    <header class="mt-8 border-b border-slate-200 pb-8">
      <p class="text-sm font-black uppercase tracking-wide text-emerald-700">Tag</p>
      <h1 class="mt-3 text-4xl font-black tracking-tight text-slate-950">#{tag}</h1>
    </header>
    <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {taggedArticles.map((article) => <ArticleCard article={article} />)}
    </div>
  </main>
</Layout>
