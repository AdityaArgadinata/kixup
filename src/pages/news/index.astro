---
import { getCollection } from 'astro:content';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import InfiniteArticles from '../../components/InfiniteArticles.astro';
import Layout from '../../layouts/Layout.astro';
import { sortArticles } from '../../lib/site';

const articles = sortArticles(await getCollection('articles', ({ data }) => !data.draft));
---

<Layout
  title="Soccer News"
  description="Latest soccer news context and explainers from Kixball."
>
  <main class="mx-auto max-w-[90rem] px-4 py-8 sm:px-6 lg:px-8">
    <Breadcrumbs items={[{ label: 'News' }]} />
    <header class="mt-8 max-w-3xl">
      <p class="text-sm font-black uppercase tracking-wide text-emerald-700">News</p>
      <h1 class="mt-3 text-4xl font-black tracking-tight text-slate-950 sm:text-5xl">Soccer News</h1>
      <p class="mt-4 text-lg leading-8 text-slate-600">
        Latest soccer explainers, news context, and analysis for American fans.
      </p>
    </header>

    <section class="mt-8 border border-slate-200 bg-white">
      <InfiniteArticles articles={articles} variant="list" />
    </section>
  </main>
</Layout>
