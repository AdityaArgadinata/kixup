---
import { getCollection } from 'astro:content';
import InfiniteArticles from '../components/InfiniteArticles.astro';
import NewsletterBox from '../components/NewsletterBox.astro';
import ScoreboardWidget from '../components/ScoreboardWidget.astro';
import Layout from '../layouts/Layout.astro';
import { SITE, categories, formatDate, getArticleUrl, getReadingTime, sortArticles } from '../lib/site';

const articles = sortArticles(await getCollection('articles', ({ data }) => !data.draft));
const [featured, ...latest] = articles;
const topStories = latest.slice(0, 3);
const latestFeed = latest.slice(3);
const popular = latest.slice(0, 8);
---

<Layout title={SITE.name} description={SITE.defaultDescription} image={featured?.data.image}>
  <main>
    <section class="border-b border-slate-200 bg-white">
      <div class="mx-auto max-w-[90rem] px-4 py-4 sm:px-6 lg:px-8">
        <div class="flex flex-col gap-2 md:flex-row md:items-center">
          <p class="w-fit bg-emerald-700 px-3 py-1 text-xs font-black uppercase tracking-wide text-white">Latest</p>
          <p class="text-sm font-semibold text-slate-700">World Cup scores, soccer explainers, USMNT, MLS, Premier League, transfers, and soccer business.</p>
        </div>
      </div>
    </section>

    <section class="mx-auto grid max-w-[90rem] gap-6 px-4 py-6 sm:px-6 lg:grid-cols-[minmax(0,1fr)_400px] lg:px-8">
      <div class="space-y-6">
        {featured && (
          <article class="border border-slate-200 bg-white">
            <a href={getArticleUrl(featured)} class="block bg-slate-100">
              <img
                src={featured.data.image}
                alt={featured.data.imageAlt}
                width="1200"
                height="675"
                loading="eager"
                decoding="async"
                class="aspect-[16/9] w-full object-cover"
              />
            </a>
            <div class="p-5 sm:p-6">
              <p class="text-xs font-black uppercase tracking-wide text-emerald-700">{featured.data.category}</p>
              <h1 class="mt-3 text-3xl font-black leading-tight tracking-tight text-slate-950 sm:text-5xl">
                <a class="hover:text-emerald-700" href={getArticleUrl(featured)}>{featured.data.title}</a>
              </h1>
              <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">{featured.data.description}</p>
              <p class="mt-4 text-xs font-semibold uppercase tracking-wide text-slate-500">
                {formatDate(featured.data.publishedAt)} · {getReadingTime(featured.body)}
              </p>
            </div>
          </article>
        )}

        <section class="grid gap-4 md:grid-cols-3">
          {topStories.map((article) => (
            <article class="border border-slate-200 bg-white">
              <a href={getArticleUrl(article)} class="block bg-slate-100">
                <img
                  src={article.data.image}
                  alt={article.data.imageAlt}
                  width="600"
                  height="338"
                  loading="lazy"
                  decoding="async"
                  class="aspect-video w-full object-cover"
                />
              </a>
              <div class="p-4">
                <p class="text-xs font-black uppercase tracking-wide text-emerald-700">{article.data.category}</p>
                <h2 class="mt-2 text-lg font-black leading-snug text-slate-950">
                  <a class="hover:text-emerald-700" href={getArticleUrl(article)}>{article.data.title}</a>
                </h2>
              </div>
            </article>
          ))}
        </section>

        <section class="border border-slate-200 bg-white">
          <div class="border-b border-slate-200 px-5 py-4">
            <h2 class="text-xl font-black tracking-tight text-slate-950">Latest News & Explainers</h2>
          </div>
          <InfiniteArticles articles={latestFeed} variant="list" headingLevel="h3" />
        </section>
      </div>

      <aside class="space-y-6">
        <ScoreboardWidget compact limit={5} showViewMore />

        <section class="border border-slate-200 bg-white p-5">
          <h2 class="text-base font-black tracking-tight text-slate-950">Most Read</h2>
          <ol class="mt-4 divide-y divide-slate-200">
            {popular.map((article, index) => (
              <li class="grid grid-cols-[32px_1fr] gap-3 py-3">
                <span class="text-lg font-black tabular-nums text-emerald-700">{index + 1}</span>
                <a class="text-sm font-bold leading-5 text-slate-800 hover:text-emerald-700" href={getArticleUrl(article)}>
                  {article.data.title}
                </a>
              </li>
            ))}
          </ol>
        </section>

        <section class="border border-slate-200 bg-white p-5">
          <h2 class="text-base font-black tracking-tight text-slate-950">Sections</h2>
          <div class="mt-4 grid gap-2">
            {categories.map((category) => (
              <a class="border border-slate-200 px-3 py-2 text-sm font-bold text-slate-700 hover:border-emerald-500 hover:text-emerald-700" href={`/${category.slug}/`}>
                {category.name}
              </a>
            ))}
          </div>
        </section>
      </aside>
    </section>

    <div class="mx-auto max-w-[90rem] px-4 py-8 sm:px-6 lg:px-8">
      <NewsletterBox />
    </div>
  </main>
</Layout>
