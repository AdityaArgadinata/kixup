---
import { SITE } from '../lib/site';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
}

const {
  title,
  description,
  canonical = new URL(Astro.url.pathname, SITE.url).toString(),
  image = '/images/soccer-explainers-default.svg',
  type = 'website',
  noindex = false,
} = Astro.props;

const fullTitle = title === SITE.name ? title : `${title} | ${SITE.name}`;
const imageUrl = new URL(image, SITE.url).toString();
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />
<meta name="googlebot" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />
<link rel="canonical" href={canonical} />
<link rel="alternate" type="application/rss+xml" title={`${SITE.name} RSS`} href={new URL('/rss.xml', SITE.url).toString()} />
<meta name="theme-color" content="#047857" />
<meta name="application-name" content={SITE.name} />
<meta name="apple-mobile-web-app-title" content={SITE.name} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:locale" content={SITE.locale} />
<meta property="og:type" content={type} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={imageUrl} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />
