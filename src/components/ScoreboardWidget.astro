---
interface Props {
  compact?: boolean;
  kicker?: string;
  limit?: number;
  title?: string;
  description?: string;
  endpoint?: string;
  emptyMessage?: string;
  display?: 'scores' | 'schedule';
  showViewMore?: boolean;
  viewMoreHref?: string;
}

const {
  compact = false,
  kicker = 'Latest scores',
  limit,
  title = 'World Cup scores',
  description = 'Latest World Cup results from the last seven days, powered by football-data.org.',
  endpoint = '/api/scoreboard.json',
  emptyMessage = 'No World Cup scores are available for the selected window.',
  display = 'scores',
  showViewMore = false,
  viewMoreHref = '/scores/',
} = Astro.props;
---

<section
  class:list={[
    'border border-slate-200 bg-white',
    compact ? 'p-5' : 'p-6 sm:p-8',
  ]}
  data-scoreboard
  data-endpoint={endpoint}
  data-limit={limit}
  data-empty-message={emptyMessage}
  data-display={display}
  data-compact={compact ? 'true' : 'false'}
>
  <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class={compact ? 'text-xs font-black uppercase tracking-wide text-emerald-700' : 'text-sm font-black uppercase tracking-wide text-emerald-700'}>{kicker}</p>
      <h2 class={compact ? 'mt-1 text-xl font-black tracking-tight text-slate-950' : 'mt-2 text-3xl font-black tracking-tight text-slate-950'}>
        {title}
      </h2>
      <p class={compact ? 'mt-1 text-xs leading-5 text-slate-600' : 'mt-2 text-sm leading-6 text-slate-600'}>
        {description}
      </p>
    </div>
    {showViewMore && (
      <a
        href={viewMoreHref}
        class="w-fit border border-slate-300 bg-white px-4 py-2 text-sm font-bold text-slate-800 hover:border-emerald-600 hover:text-emerald-700"
      >
        View more
      </a>
    )}
  </div>

  <div class="mt-6" data-scoreboard-body>
    <div class:list={['grid gap-3', compact ? '' : 'md:grid-cols-2']}>
      <div class="border border-slate-200 bg-slate-50 p-3">
        <div class="h-4 w-28 animate-pulse bg-slate-200"></div>
        <div class="mt-4 h-5 w-full animate-pulse bg-slate-200"></div>
        <div class="mt-3 h-5 w-4/5 animate-pulse bg-slate-200"></div>
      </div>
      <div class="border border-slate-200 bg-slate-50 p-3">
        <div class="h-4 w-28 animate-pulse bg-slate-200"></div>
        <div class="mt-4 h-5 w-full animate-pulse bg-slate-200"></div>
        <div class="mt-3 h-5 w-4/5 animate-pulse bg-slate-200"></div>
      </div>
    </div>
  </div>

  <p class="mt-4 text-xs text-slate-500" data-scoreboard-meta>
    Loading latest available scores.
  </p>
</section>

<script>
  import '../scripts/scoreboard-widget';
</script>
