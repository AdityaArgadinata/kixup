---
interface Props {
  compact?: boolean;
  limit?: number;
  showViewMore?: boolean;
}

const { compact = false, limit, showViewMore = false } = Astro.props;
---

<section
  class:list={[
    'border border-slate-200 bg-white',
    compact ? 'p-5' : 'p-6 sm:p-8',
  ]}
  data-scoreboard
  data-endpoint="/api/scoreboard.json"
  data-limit={limit}
>
  <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-black uppercase tracking-wide text-emerald-700">Latest scores</p>
      <h2 class={compact ? 'mt-2 text-2xl font-black tracking-tight text-slate-950' : 'mt-2 text-3xl font-black tracking-tight text-slate-950'}>
        World Cup scores
      </h2>
      <p class="mt-2 text-sm leading-6 text-slate-600">
        Latest World Cup results from the last seven days, powered by football-data.org.
      </p>
    </div>
    {showViewMore && (
      <a
        href="/scores/"
        class="w-fit border border-slate-300 bg-white px-4 py-2 text-sm font-bold text-slate-800 hover:border-emerald-600 hover:text-emerald-700"
      >
        View more
      </a>
    )}
  </div>

  <div class="mt-6" data-scoreboard-body>
    <div class="grid gap-3 md:grid-cols-2">
      <div class="border border-slate-200 bg-slate-50 p-4">
        <div class="h-4 w-28 animate-pulse bg-slate-200"></div>
        <div class="mt-4 h-5 w-full animate-pulse bg-slate-200"></div>
        <div class="mt-3 h-5 w-4/5 animate-pulse bg-slate-200"></div>
      </div>
      <div class="border border-slate-200 bg-slate-50 p-4">
        <div class="h-4 w-28 animate-pulse bg-slate-200"></div>
        <div class="mt-4 h-5 w-full animate-pulse bg-slate-200"></div>
        <div class="mt-3 h-5 w-4/5 animate-pulse bg-slate-200"></div>
      </div>
    </div>
  </div>

  <p class="mt-4 text-xs text-slate-500" data-scoreboard-meta>
    Loading latest available scores.
  </p>
</section>

<script>
  const statusLabels = new Map([
    ['NS', 'Scheduled'],
    ['LIVE', 'In play'],
    ['1H', 'First half'],
    ['HT', 'Halftime'],
    ['2H', 'Second half'],
    ['ET', 'Extra time'],
    ['P', 'Penalties'],
    ['FT', 'Full Time'],
    ['AET', 'After Extra Time'],
    ['PEN', 'After Penalties'],
    ['PST', 'Postponed'],
    ['SUSP', 'Suspended'],
    ['CANC', 'Canceled'],
  ]);

  document.querySelectorAll('[data-scoreboard]').forEach((root) => {
    const endpoint = root.getAttribute('data-endpoint') ?? '/api/scoreboard.json';
    const limit = Number(root.getAttribute('data-limit')) || undefined;
    const body = root.querySelector('[data-scoreboard-body]');
    const meta = root.querySelector('[data-scoreboard-meta]');

    async function loadScoreboard() {
      if (!body || !meta) return;

      try {
        const response = await fetch(endpoint, {
          headers: {
            Accept: 'application/json',
          },
        });
        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.message || 'Unable to load scores.');
        }

        const matches = Array.isArray(data.matches) && limit ? data.matches.slice(0, limit) : data.matches;
        body.innerHTML = renderMatches(matches, data.message);
        meta.textContent = data.generatedAt
          ? `Updated ${new Date(data.generatedAt).toLocaleTimeString('en-US', {
              hour: 'numeric',
              minute: '2-digit',
              timeZoneName: 'short',
            })}.`
          : 'Updated recently.';
      } catch (error) {
        body.innerHTML = renderEmpty(error instanceof Error ? error.message : 'Unable to load scores.');
        meta.textContent = 'Scoreboard unavailable right now.';
      }
    }

    loadScoreboard();
  });

  function renderMatches(matches, message) {
    if (!Array.isArray(matches) || matches.length === 0) {
      return renderEmpty(message || 'No World Cup scores are available for the last seven days.');
    }

    return `<div class="grid gap-3 md:grid-cols-2">${matches.map(renderMatch).join('')}</div>`;
  }

  function renderMatch(match) {
    const status = statusLabels.get(match.statusShort) || match.status || match.statusShort;
    const time = match.statusShort === 'NS'
      ? new Date(match.kickoff).toLocaleTimeString('en-US', {
          hour: 'numeric',
          minute: '2-digit',
          timeZoneName: 'short',
        })
      : `${status}${match.elapsed ? ` · ${match.elapsed}'` : ''}`;

    return `
      <article class="border border-slate-200 bg-slate-50 p-4">
        <div class="flex items-center justify-between gap-3 text-xs font-bold uppercase tracking-wide text-slate-500">
          <span>${escapeHtml(match.league)}</span>
          <span>${escapeHtml(time)}</span>
        </div>
        <div class="mt-4 space-y-3">
          ${renderTeam(match.home)}
          ${renderTeam(match.away)}
        </div>
      </article>
    `;
  }

  function renderTeam(team) {
    const score = team.score === null || team.score === undefined ? '-' : team.score;

    return `
      <div class="flex items-center justify-between gap-4">
        <div class="flex min-w-0 items-center gap-3">
          ${team.logo ? `<img src="${team.logo}" alt="" loading="lazy" decoding="async" class="h-6 w-6 shrink-0 object-contain" />` : ''}
          <span class="truncate text-sm font-bold text-slate-950">${escapeHtml(team.name)}</span>
        </div>
        <span class="text-lg font-black tabular-nums text-emerald-700">${score}</span>
      </div>
    `;
  }

  function renderEmpty(message) {
    return `
      <div class="border border-dashed border-slate-300 bg-slate-50 p-5">
        <p class="text-sm font-bold text-slate-950">Latest scores are ready.</p>
        <p class="mt-2 text-sm leading-6 text-slate-600">${escapeHtml(message)}</p>
      </div>
    `;
  }

  function escapeHtml(value) {
    return String(value)
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');
  }
</script>
