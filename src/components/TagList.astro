---
import { slugify } from '../lib/site';

interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

<ul class="flex flex-wrap gap-2" aria-label="Article tags">
  {tags.map((tag) => (
    <li>
      <a href={`/tags/${slugify(tag)}/`} class="border border-slate-200 bg-white px-3 py-1 text-xs font-semibold text-slate-600 hover:border-emerald-600 hover:text-emerald-700">
        #{tag}
      </a>
    </li>
  ))}
</ul>
