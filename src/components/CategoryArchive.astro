---
import { getCollection } from 'astro:content';
import Breadcrumbs from './Breadcrumbs.astro';
import InfiniteArticles from './InfiniteArticles.astro';
import Layout from '../layouts/Layout.astro';
import { getCategory, sortArticles } from '../lib/site';

interface Props {
  categorySlug: string;
}

const { categorySlug } = Astro.props;
const category = getCategory(categorySlug);

if (!category) {
  throw new Error(`Unknown category: ${categorySlug}`);
}

const articles = sortArticles(
  (await getCollection('articles', ({ data }) => !data.draft)).filter(
    (article) => article.data.category === category.name,
  ),
);
---

<Layout title={category.name} description={category.description}>
  <main class="mx-auto max-w-[90rem] px-4 py-8 sm:px-6 lg:px-8">
    <Breadcrumbs items={[{ label: category.name }]} />
    <header class="mt-8 border-b border-slate-200 pb-8">
      <p class="text-sm font-black uppercase tracking-wide text-emerald-700">Section</p>
      <h1 class="mt-3 text-4xl font-black tracking-tight text-slate-950 sm:text-5xl">{category.name}</h1>
      <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-600">{category.description}</p>
    </header>
    <InfiniteArticles articles={articles} />
  </main>
</Layout>
