---
import ArticleCard from './ArticleCard.astro';
import { formatDate, getArticleUrl, getReadingTime, type Article } from '../lib/site';

interface Props {
  articles: Article[];
  variant?: 'grid' | 'list';
  batchSize?: number;
  headingLevel?: 'h2' | 'h3';
}

const { articles, variant = 'grid', batchSize = 12, headingLevel = 'h2' } = Astro.props;
const Heading = headingLevel;
---

<div
  data-infinite-articles
  data-batch-size={batchSize}
  class={variant === 'grid' ? 'mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3' : 'divide-y divide-slate-200'}
>
  {
    articles.map((article) =>
      variant === 'grid' ? (
        <div data-article-item>
          <ArticleCard article={article} />
        </div>
      ) : (
        <article data-article-item class="grid gap-4 p-5 sm:grid-cols-[220px_1fr]">
          <a href={getArticleUrl(article)} class="block bg-slate-100">
            <img
              src={article.data.image}
              alt={article.data.imageAlt}
              width="440"
              height="248"
              loading="lazy"
              decoding="async"
              class="aspect-video w-full object-cover"
            />
          </a>
          <div>
            <p class="text-xs font-black uppercase tracking-wide text-emerald-700">{article.data.category}</p>
            <Heading class="mt-2 text-2xl font-black leading-tight text-slate-950">
              <a class="hover:text-emerald-700" href={getArticleUrl(article)}>{article.data.title}</a>
            </Heading>
            <p class="mt-2 text-sm leading-6 text-slate-600">{article.data.description}</p>
            <p class="mt-3 text-xs font-semibold uppercase tracking-wide text-slate-500">
              {formatDate(article.data.publishedAt)} · {getReadingTime(article.body)}
            </p>
          </div>
        </article>
      ),
    )
  }
</div>

{
  articles.length > batchSize && (
    <div class="mt-6 flex flex-col items-center gap-3" data-infinite-controls>
      <div class="hidden items-center gap-2 text-sm font-bold text-slate-500" data-infinite-spinner>
        <span class="h-5 w-5 animate-spin rounded-full border-2 border-slate-300 border-t-emerald-700" aria-hidden="true" />
        <span>Loading more articles...</span>
      </div>
      <button
        type="button"
        class="border border-slate-300 bg-white px-4 py-2 text-sm font-bold text-slate-800 hover:border-emerald-600 hover:text-emerald-700"
        data-infinite-load
      >
        Load more articles
      </button>
    </div>
  )
}

<script is:inline>
  for (const list of document.querySelectorAll('[data-infinite-articles]')) {
    if (list.dataset.infiniteReady) continue;
    list.dataset.infiniteReady = 'true';

    const items = [...list.querySelectorAll('[data-article-item]')];
    const batchSize = Number(list.getAttribute('data-batch-size')) || 12;
    const controls = list.nextElementSibling?.matches('[data-infinite-controls]') ? list.nextElementSibling : null;
    const button = controls?.querySelector('[data-infinite-load]');
    const spinner = controls?.querySelector('[data-infinite-spinner]');
    let shown = Math.min(batchSize, items.length);
    let observer;
    let loading = false;

    const render = () => {
      items.forEach((item, index) => {
        item.hidden = index >= shown;
      });

      if (controls && shown >= items.length) {
        controls.hidden = true;
        observer?.disconnect();
      }
    };

    const reveal = () => {
      if (loading || shown >= items.length) return;

      loading = true;
      if (button) button.disabled = true;
      spinner?.classList.remove('hidden');
      spinner?.classList.add('flex');

      setTimeout(() => {
        shown = Math.min(shown + batchSize, items.length);
        loading = false;
        if (button) button.disabled = false;
        spinner?.classList.add('hidden');
        spinner?.classList.remove('flex');
        render();
      }, 250);
    };

    render();
    button?.addEventListener('click', reveal);

    if (controls && 'IntersectionObserver' in window) {
      observer = new IntersectionObserver((entries) => {
        if (entries.some((entry) => entry.isIntersecting)) reveal();
      }, { rootMargin: '500px' });
      observer.observe(controls);
    }
  }
</script>
