---
import { categories, SITE } from '../lib/site';
---

<footer class="mt-16 border-t border-slate-700 bg-[#111820] text-slate-200">
  <div class="mx-auto grid max-w-[90rem] gap-10 px-4 py-10 sm:px-6 md:grid-cols-[1.5fr_1fr_1fr] lg:px-8">
    <div>
      <p class="flex items-center gap-2 text-lg font-black text-white">
        <img src={SITE.logo} alt="" class="h-12 w-auto object-contain" loading="lazy" decoding="async" />
      </p>
      <p class="mt-3 max-w-md text-sm leading-6 text-slate-400">{SITE.defaultDescription}</p>
    </div>
    <nav aria-label="Footer sections">
      <h2 class="text-sm font-bold uppercase tracking-wide text-white">Sections</h2>
      <ul class="mt-3 space-y-2 text-sm">
        {categories.map((category) => (
          <li><a class="text-slate-400 hover:text-white" href={`/${category.slug}/`}>{category.name}</a></li>
        ))}
      </ul>
    </nav>
    <nav aria-label="Policies">
      <h2 class="text-sm font-bold uppercase tracking-wide text-white">Site</h2>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a class="text-slate-400 hover:text-white" href="/contact/">Contact</a></li>
        <li><a class="text-slate-400 hover:text-white" href="/corrections-policy/">Corrections</a></li>
        <li><a class="text-slate-400 hover:text-white" href="/ai-usage-policy/">AI Usage</a></li>
        <li><a class="text-slate-400 hover:text-white" href="/privacy-policy/">Privacy</a></li>
        <li><a class="text-slate-400 hover:text-white" href="/terms/">Terms</a></li>
        <li><a class="text-slate-400 hover:text-white" href="/disclaimer/">Disclaimer</a></li>
      </ul>
    </nav>
  </div>
  <div class="border-t border-slate-700">
    <div class="mx-auto max-w-[90rem] px-4 py-4 text-center text-xs text-slate-500 sm:px-6 lg:px-8">
      © {new Date().getFullYear()} {SITE.name}. Independent soccer explainers for US readers.
    </div>
  </div>
</footer>
