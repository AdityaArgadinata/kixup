---
import CategoryBadge from './CategoryBadge.astro';
import { formatDate, getArticleUrl, getReadingTime, type Article } from '../lib/site';

interface Props {
  article: Article;
  featured?: boolean;
}

const { article, featured = false } = Astro.props;
---

<article class:list={['group overflow-hidden border border-slate-200 bg-white', featured ? 'grid gap-0 md:grid-cols-2' : '']}>
  <a href={getArticleUrl(article)} class="block bg-slate-100">
    <img
      src={article.data.image}
      alt={article.data.imageAlt}
      width="1200"
      height="675"
      loading={featured ? 'eager' : 'lazy'}
      decoding="async"
      class="aspect-video w-full object-cover transition duration-300 group-hover:scale-[1.02]"
    />
  </a>
  <div class={featured ? 'p-6 sm:p-8' : 'p-5'}>
    <CategoryBadge category={article.data.category} />
    <h2 class={featured ? 'mt-4 text-3xl font-black leading-tight text-slate-950' : 'mt-4 text-xl font-black leading-snug text-slate-950'}>
      <a href={getArticleUrl(article)} class="hover:text-emerald-700">{article.data.title}</a>
    </h2>
    <p class="mt-3 text-sm leading-6 text-slate-600">{article.data.description}</p>
    <p class="mt-4 text-xs font-semibold uppercase tracking-wide text-slate-500">
      {formatDate(article.data.publishedAt)} · {getReadingTime(article.body)}
    </p>
  </div>
</article>
