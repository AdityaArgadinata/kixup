---
interface Props {
  endpoint?: string;
}

const { endpoint = '/api/schedule.json' } = Astro.props;
---

<section
  class="border border-slate-200 bg-white p-5 sm:p-6"
  data-schedule-table
  data-endpoint={endpoint}
>
  <div class="flex flex-col gap-5 md:flex-row md:items-start md:justify-between">
    <div>
      <h2 class="text-3xl font-black tracking-tight text-slate-950 sm:text-5xl">FIFA World Cup Schedule</h2>
      <p class="mt-3 text-sm leading-6 text-slate-600">
        Match times are shown in your local timezone.
      </p>
    </div>
    <div class="w-fit rounded-full border border-slate-300 px-4 py-2 text-sm font-bold text-slate-700">
      FIFA World Cup
    </div>
  </div>

  <div class="mt-8" data-schedule-body>
    <div class="space-y-5">
      <div class="h-8 w-64 animate-pulse bg-slate-100"></div>
      <div class="h-28 animate-pulse bg-slate-100"></div>
      <div class="h-8 w-64 animate-pulse bg-slate-100"></div>
      <div class="h-28 animate-pulse bg-slate-100"></div>
    </div>
  </div>

  <p class="mt-5 text-xs text-slate-500" data-schedule-meta>Loading schedule.</p>
</section>

<script>
  const statusLabels = new Map([
    ['NS', 'Scheduled'],
    ['LIVE', 'In play'],
    ['HT', 'Halftime'],
    ['FT', 'FT'],
    ['AET', 'AET'],
    ['PEN', 'PEN'],
    ['PST', 'Postponed'],
    ['SUSP', 'Suspended'],
    ['CANC', 'Canceled'],
  ]);

  document.querySelectorAll('[data-schedule-table]').forEach((root) => {
    const endpoint = root.getAttribute('data-endpoint') ?? '/api/schedule.json';
    const bodyEl = root.querySelector('[data-schedule-body]');
    const metaEl = root.querySelector('[data-schedule-meta]');

    async function loadSchedule() {
      if (!bodyEl || !metaEl) return;

      try {
        const response = await fetch(endpoint, {
          headers: { Accept: 'application/json' },
        });
        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.message || 'Unable to load schedule.');
        }

        const matches = Array.isArray(data.matches) ? data.matches : [];
        const groupedDays = groupMatchesByDay(matches);

        if (groupedDays.length === 0) {
          bodyEl.innerHTML = renderEmpty(data.message || 'No World Cup matches are available for this date range.');
        } else {
          bodyEl.innerHTML = groupedDays.map(renderDayGroup).join('');
        }

        metaEl.textContent = data.generatedAt
          ? `Updated ${new Date(data.generatedAt).toLocaleTimeString('en-US', {
              hour: 'numeric',
              minute: '2-digit',
              timeZoneName: 'short',
            })}.`
          : 'Updated recently.';
      } catch (error) {
        bodyEl.innerHTML = renderEmpty(error instanceof Error ? error.message : 'Unable to load schedule.');
        metaEl.textContent = 'Schedule unavailable right now.';
      }
    }

    loadSchedule();
  });

  function groupMatchesByDay(matches) {
    const grouped = new Map();

    matches.forEach((match) => {
      const date = new Date(match.kickoff);
      const key = date.toLocaleDateString('en-CA', { timeZone: 'Asia/Jakarta' });

      if (!grouped.has(key)) {
        grouped.set(key, {
          key,
          date,
          matches: [],
        });
      }

      grouped.get(key).matches.push(match);
    });

    return Array.from(grouped.values())
      .sort((a, b) => a.date.getTime() - b.date.getTime())
      .map((day) => ({
        ...day,
        matches: day.matches.sort((a, b) => new Date(a.kickoff).getTime() - new Date(b.kickoff).getTime()),
      }));
  }

  function renderDayGroup(day) {
    const heading = day.date.toLocaleDateString('en-US', {
      weekday: 'long',
      month: 'long',
      day: 'numeric',
      year: 'numeric',
      timeZone: 'Asia/Jakarta',
    });
    const hasFinished = day.matches.some((match) => ['FT', 'AET', 'PEN'].includes(match.statusShort));

    return `
      <section class="mt-10 first:mt-0">
        <h3 class="border-b border-slate-200 pb-4 text-2xl font-black tracking-tight text-slate-900">${escapeHtml(heading)}</h3>
        <div class="overflow-x-auto">
          <table class="min-w-[620px] w-full border-collapse text-sm">
            <thead>
              <tr class="border-b border-slate-200 text-left text-xs font-black uppercase tracking-wide text-slate-500">
                <th class="w-[60%] px-3 py-3 text-center">Match</th>
                <th class="w-[20%] px-3 py-3">${hasFinished ? 'Result' : 'Time'}</th>
                <th class="w-[20%] px-3 py-3">Status</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              ${day.matches.map(renderMatchRow).join('')}
            </tbody>
          </table>
        </div>
      </section>
    `;
  }

  function renderMatchRow(match) {
    const isFinished = ['FT', 'AET', 'PEN'].includes(match.statusShort);
    const kickoff = new Date(match.kickoff);
    const timeLabel = kickoff.toLocaleTimeString('en-US', {
      hour: 'numeric',
      minute: '2-digit',
      timeZone: 'Asia/Jakarta',
    });
    const result = isFinished
      ? `${formatScore(match.home.score)} - ${formatScore(match.away.score)}`
      : timeLabel;
    const status = statusLabels.get(match.statusShort) || match.status || match.statusShort;

    return `
      <tr class="odd:bg-white even:bg-slate-50">
        <td class="px-3 py-3">
          <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-3">
            ${renderTeam(match.home, 'justify-end text-right')}
            <span class="font-bold tabular-nums text-blue-600">${escapeHtml(isFinished ? result : 'v')}</span>
            ${renderTeam(match.away, 'justify-start text-left')}
          </div>
        </td>
        <td class="px-3 py-3 font-bold text-blue-600">${escapeHtml(result)}</td>
        <td class="px-3 py-3 text-slate-600">${escapeHtml(status)}</td>
      </tr>
    `;
  }

  function renderTeam(team, alignClass) {
    const name = team?.name || 'TBD';
    const logo = team?.logo
      ? `<img src="${team.logo}" alt="" loading="lazy" decoding="async" class="h-5 w-5 shrink-0 object-contain" />`
      : '';
    const reverse = alignClass.includes('justify-end');

    return `
      <div class="flex min-w-0 items-center gap-2 ${alignClass}">
        ${reverse ? `<span class="truncate font-medium text-blue-600">${escapeHtml(name)}</span>${logo}` : `${logo}<span class="truncate font-medium text-blue-600">${escapeHtml(name)}</span>`}
      </div>
    `;
  }

  function renderEmpty(message) {
    return `
      <div class="border border-dashed border-slate-300 bg-slate-50 p-6">
        <p class="text-sm font-bold text-slate-950">Schedule unavailable.</p>
        <p class="mt-2 text-sm leading-6 text-slate-600">${escapeHtml(message)}</p>
      </div>
    `;
  }

  function formatScore(value) {
    return value === null || value === undefined ? '-' : String(value);
  }

  function escapeHtml(value) {
    return String(value)
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');
  }
</script>
