---
import { primaryNav, SITE } from '../lib/site';
---

<header class="border-b border-slate-200 bg-white">
  <div class="border-b border-slate-100 bg-slate-50">
    <div class="mx-auto flex max-w-[90rem] flex-col gap-3 px-4 py-2 sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
      <div class="grid gap-2 sm:grid-cols-3 lg:flex-1" data-header-schedule>
        <a class="grid min-h-14 place-items-center border border-slate-200 bg-white px-3 py-2 text-center text-xs font-bold text-slate-500" href="/schedule/">
          <span>Schedule loading</span>
        </a>
        <a class="hidden min-h-14 place-items-center border border-slate-200 bg-white px-3 py-2 text-center text-xs font-bold text-slate-500 sm:grid" href="/schedule/">
          <span>Schedule loading</span>
        </a>
        <a class="hidden min-h-14 place-items-center border border-slate-200 bg-white px-3 py-2 text-center text-xs font-bold text-slate-500 sm:grid" href="/schedule/">
          <span>Schedule loading</span>
        </a>
      </div>
      <nav class="flex gap-4 text-xs font-bold uppercase tracking-wide text-slate-500" aria-label="Utility">
        <a class="hover:text-emerald-700" href="/scores/">Scores</a>
        <a class="hover:text-emerald-700" href="/rss.xml">RSS</a>
      </nav>
    </div>
  </div>

  <div class="mx-auto flex max-w-[90rem] flex-col gap-4 px-4 py-5 sm:px-6 lg:flex-row lg:items-end lg:justify-between lg:px-8">
    <a href="/" class="inline-flex w-fit items-center" aria-label={`${SITE.name} home`}>
      <img src={SITE.logo} alt="" class="h-12 w-auto shrink-0 object-contain" loading="eager" decoding="async" />
    </a>
    <nav class="flex gap-5 text-sm font-semibold text-slate-600" aria-label="Site">
      <a class="hover:text-emerald-700" href="/about/">About</a>
      <a class="hover:text-emerald-700" href="/editorial-policy/">Editorial Policy</a>
      <a class="hover:text-emerald-700" href="/contact/">Contact</a>
    </nav>
  </div>

  <nav class="border-t border-slate-200 bg-slate-950" aria-label="Sections">
    <div class="mx-auto flex max-w-[90rem] gap-1 overflow-x-auto px-4 py-0 text-sm font-bold text-white sm:px-6 lg:px-8">
      {primaryNav.map((item) => (
        <a class="flex shrink-0 items-center px-4 py-3 hover:bg-emerald-700" href={item.href}>
          {item.name}
        </a>
      ))}
      <button
        class="ml-auto grid min-h-11 w-11 shrink-0 place-items-center hover:bg-emerald-700"
        type="button"
        aria-label="Open search"
        aria-haspopup="dialog"
        data-search-open
      >
        <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round">
          <path d="m21 21-4.35-4.35" />
          <circle cx="11" cy="11" r="7" />
        </svg>
      </button>
    </div>
  </nav>

  <div class="fixed inset-0 z-50 hidden items-start justify-center bg-slate-950/40 px-4 py-16 backdrop-blur-sm sm:py-24" data-search-modal>
    <div class="w-full max-w-2xl border border-slate-200 bg-white shadow-2xl" role="dialog" aria-modal="true" aria-labelledby="search-modal-title">
      <div class="flex items-center justify-between border-b border-slate-200 px-4 py-3">
        <h2 id="search-modal-title" class="text-sm font-black uppercase tracking-wide text-slate-950">Search Kixball</h2>
        <button class="grid h-9 w-9 place-items-center text-slate-500 hover:bg-slate-100 hover:text-slate-950" type="button" aria-label="Close search" data-search-close>
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 6 6 18" />
            <path d="m6 6 12 12" />
          </svg>
        </button>
      </div>
      <form class="grid gap-3 p-4 sm:grid-cols-[minmax(0,1fr)_auto]" action="/search/" method="get" role="search">
        <label class="sr-only" for="site-search-modal">Search articles</label>
        <input
          id="site-search-modal"
          name="q"
          type="search"
          autocomplete="off"
          placeholder="Search news, teams, topics"
          class="min-h-12 w-full border border-slate-300 px-4 text-base font-semibold text-slate-900 outline-none placeholder:text-slate-400 focus:border-emerald-600 focus:ring-2 focus:ring-emerald-100"
          data-search-modal-input
        />
        <button class="inline-flex min-h-12 items-center justify-center gap-2 bg-emerald-700 px-5 text-sm font-black uppercase tracking-wide text-white hover:bg-emerald-800" type="submit">
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round">
            <path d="m21 21-4.35-4.35" />
            <circle cx="11" cy="11" r="7" />
          </svg>
          Search
        </button>
      </form>
    </div>
  </div>
</header>

<script>
  const searchModal = document.querySelector('[data-search-modal]');
  const searchOpenButton = document.querySelector('[data-search-open]');
  const searchCloseButton = document.querySelector('[data-search-close]');
  const searchModalInput = document.querySelector('[data-search-modal-input]');

  searchOpenButton?.addEventListener('click', () => {
    if (!(searchModal instanceof HTMLElement)) return;

    searchModal.classList.remove('hidden');
    searchModal.classList.add('flex');
    document.body.style.overflow = 'hidden';

    if (searchModalInput instanceof HTMLInputElement) {
      window.setTimeout(() => searchModalInput.focus(), 0);
    }
  });

  searchCloseButton?.addEventListener('click', closeSearchModal);
  searchModal?.addEventListener('click', (event) => {
    if (event.target === searchModal) closeSearchModal();
  });
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeSearchModal();
  });

  function closeSearchModal() {
    if (!(searchModal instanceof HTMLElement)) return;

    searchModal.classList.add('hidden');
    searchModal.classList.remove('flex');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('[data-header-schedule]').forEach((root) => {
    async function loadHeaderSchedule() {
      try {
        const response = await fetch('/api/schedule.json', {
          headers: { Accept: 'application/json' },
        });
        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.message || 'Unable to load schedule.');
        }

        const matches = Array.isArray(data.matches) ? data.matches : [];
        const upcoming = matches
          .filter((match) => ['NS', 'LIVE', 'HT'].includes(match.statusShort))
          .sort((a, b) => new Date(a.kickoff).getTime() - new Date(b.kickoff).getTime())
          .slice(0, 3);

        const selectedMatches = upcoming.length > 0
          ? upcoming
          : matches
              .sort((a, b) => new Date(b.kickoff).getTime() - new Date(a.kickoff).getTime())
              .slice(0, 3);

        if (selectedMatches.length === 0) return;

        root.innerHTML = selectedMatches.map(renderScheduleCard).join('');
      } catch {
        root.innerHTML = `
          <a class="grid min-h-14 place-items-center border border-slate-200 bg-white px-3 py-2 text-center text-xs font-bold text-slate-500" href="/schedule/">
            <span>Schedule unavailable</span>
          </a>
        `;
      }
    }

    loadHeaderSchedule();
  });

  function renderScheduleCard(match) {
    const home = match.home?.name || 'TBD';
    const away = match.away?.name || 'TBD';
    const homeLogo = match.home?.logo || '';
    const awayLogo = match.away?.logo || '';
    const kickoff = new Date(match.kickoff);
    const time = kickoff.toLocaleTimeString('en-US', {
      hour: 'numeric',
      minute: '2-digit',
      timeZone: 'Asia/Jakarta',
    });
    const date = kickoff.toLocaleDateString('en-US', {
      month: 'short',
      day: 'numeric',
      timeZone: 'Asia/Jakarta',
    });

    return `
      <a class="grid min-h-14 min-w-0 grid-rows-[1fr_auto] border border-slate-200 bg-white px-3 py-2 text-xs hover:border-emerald-500" href="/schedule/">
        <span class="grid min-w-0 grid-cols-[1fr_24px_1fr] items-center gap-2">
          ${renderHeaderTeam(home, homeLogo, 'justify-end text-right')}
          <span class="text-center font-black text-slate-400">vs</span>
          ${renderHeaderTeam(away, awayLogo, 'justify-start text-left')}
        </span>
        <span class="mt-1 block text-center font-bold text-emerald-700">${escapeHtml(date)} · ${escapeHtml(time)}</span>
      </a>
    `;
  }

  function renderHeaderTeam(name, logo, alignClass) {
    const reverse = alignClass.includes('justify-end');
    const logoHtml = logo
      ? `<img src="${escapeHtml(logo)}" alt="" loading="lazy" decoding="async" class="h-4 w-4 shrink-0 object-contain" />`
      : '<span class="h-4 w-4 shrink-0 rounded-full bg-slate-200"></span>';
    const nameHtml = `<span class="truncate font-black text-slate-950">${escapeHtml(name)}</span>`;

    return `
      <span class="flex min-w-0 items-center gap-1.5 ${alignClass}">
        ${reverse ? `${nameHtml}${logoHtml}` : `${logoHtml}${nameHtml}`}
      </span>
    `;
  }

  function escapeHtml(value) {
    return String(value)
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');
  }
</script>
