<section class="border border-slate-200 bg-white p-6">
  <h2 class="text-xl font-black text-slate-950">Get smarter about soccer</h2>
  <p class="mt-2 text-sm leading-6 text-slate-600">
    Newsletter signup placeholder for future email publishing. No form provider is connected yet.
  </p>
  <form class="mt-5 flex flex-col gap-3 sm:flex-row" aria-label="Newsletter signup placeholder">
    <input
      class="min-h-11 flex-1 border border-slate-300 bg-white px-3 text-sm text-slate-900 placeholder:text-slate-400"
      type="email"
      name="email"
      placeholder="you@example.com"
      aria-label="Email address"
      disabled
    />
    <button class="min-h-11 bg-emerald-500 px-5 text-sm font-bold text-slate-950" type="button" disabled>
      Coming soon
    </button>
  </form>
</section>
